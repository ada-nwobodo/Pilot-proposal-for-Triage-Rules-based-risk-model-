# Copy to .env and adjust values as needed.
# All variables are optional — defaults are shown below.

# spaCy model to use (must be installed via: python -m spacy download <model>)
RISK_ENGINE_SPACY_MODEL=en_core_web_sm

# Negation detection token window sizes
RISK_ENGINE_NEGATION_PRE_WINDOW=5
RISK_ENGINE_NEGATION_POST_WINDOW=3

# Severity annotation context window
RISK_ENGINE_SEVERITY_WINDOW=3

# Score weights (must sum to 1.0)
RISK_ENGINE_ENTITY_WEIGHT=0.55
RISK_ENGINE_VITALS_WEIGHT=0.45

# Data adapter for the /examples endpoint
# Built-in options: synthetic
# Add custom adapters in clinical_nlp/adapters/ and register in ADAPTER_REGISTRY
RISK_ENGINE_DATA_ADAPTER=synthetic

# Path to the synthetic JSONL dataset (relative to repo root)
RISK_ENGINE_SYNTHETIC_DATA_PATH=data/synthetic/sample_notes.jsonl
