# Copy this file to .env and fill in values.
# .env is git-ignored — never commit real secrets.

# ── NLP engine settings (prefix: RISK_ENGINE_) ───────────────────────────────

# spaCy model to use (must be installed in the active environment)
# python -m spacy download en_core_web_sm
RISK_ENGINE_SPACY_MODEL=en_core_web_sm

# Negation detection token window sizes
RISK_ENGINE_NEGATION_PRE_WINDOW=5
RISK_ENGINE_NEGATION_POST_WINDOW=3

# Severity annotation context window
RISK_ENGINE_SEVERITY_WINDOW=3

# Data adapter for the /examples endpoint
# Built-in options: synthetic
RISK_ENGINE_DATA_ADAPTER=synthetic

# Path to the synthetic JSONL dataset (relative to repo root)
RISK_ENGINE_SYNTHETIC_DATA_PATH=data/synthetic/sample_notes.jsonl

# ── CORS (prefix: RISK_ENGINE_) ───────────────────────────────────────────────
# Comma-separated list of origins allowed to call the API.
# Local development default — replace with your deployed frontend URL.
# Example: RISK_ENGINE_ALLOWED_ORIGINS=https://myapp.vercel.app
RISK_ENGINE_ALLOWED_ORIGINS=http://localhost:8000

# ── Supabase (prefix: SUPABASE_) ──────────────────────────────────────────────
# Found in your Supabase project: Settings → API
#
# SUPABASE_URL and SUPABASE_ANON_KEY are public-safe (exposed to the frontend
# via the /config endpoint — the anon key has row-level security enforced).
#
# SUPABASE_SERVICE_ROLE_KEY is SECRET — backend only, never sent to the browser.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
